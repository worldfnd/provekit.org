---
interface Props {
  onBenchmarks?: boolean;
}
const { onBenchmarks = false } = Astro.props;

const DOCS_URL = 'https://docs.provekit.org/';

const product = [
  { label: 'DOCS', href: DOCS_URL, external: false },
  onBenchmarks
    ? { label: 'HOME', href: '/', external: false }
    : { label: 'BENCHMARKS', href: '/benchmarks', external: false },
];
const community = [
  { label: 'TELEGRAM', href: 'https://t.me/provekit', external: true },
  { label: 'TWITTER', href: 'https://twitter.com/provekit', external: true },
  { label: 'GITHUB', href: 'https://github.com/worldfnd/provekit', external: true },
];
---

<footer class="pk-footer">
  <div class="pk-footer-chips">
    <div class="pk-footer-chip-group">
      {
        product.map((l) => (
          <a
            class="pk-chip"
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </div>
    <div class="pk-footer-chip-group">
      {
        community.map((l) => (
          <a
            class="pk-chip"
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Giant ProveKit wordmark, full-bleed, clipped at the bottom. -->
  <div class="pk-footer-wordmark" aria-hidden="true">
    <img
      src="/figma/wordmark-large-blue.svg"
      alt=""
      loading="lazy"
      decoding="async"
      style="width:100%;display:block"
    />
  </div>
</footer>

<style is:global>
  .pk-footer {
    width: 1600px;
    max-width: 100%;
    padding: 48px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
    overflow: hidden;
    border-left: 1px solid var(--pk-line);
    border-right: 1px solid var(--pk-line);
    box-sizing: border-box;
  }
  .pk-footer-chips {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .pk-footer-chip-group {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pk-footer-wordmark {
    width: 100%;
    margin-top: 24px;
    margin-bottom: -16px;
    position: relative;
    cursor: pointer;
    overflow: hidden;
  }

  .pk-chip {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border: 1px solid var(--pk-line);
    background: transparent;
    font: 400 18px/1 var(--pk-font-mono);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--pk-ink);
    cursor: pointer;
    text-decoration: none;
    transition:
      background 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease;
  }
  .pk-chip:hover {
    background: var(--pk-brand);
    color: #fff;
    border-color: var(--pk-brand);
  }

  @media (max-width: 720px) {
    .pk-footer {
      padding: 24px 16px 0;
      gap: 16px;
    }
    .pk-footer-chips {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }
    .pk-footer-chip-group {
      gap: 8px;
      flex-wrap: wrap;
    }
    .pk-chip {
      flex: 1 1 calc(33.333% - 6px);
      min-width: 0;
      justify-content: center;
      padding: 10px 12px;
      font-size: 12px;
      letter-spacing: 0.06em;
    }
    .pk-footer-wordmark {
      margin-top: 16px;
      margin-bottom: 0;
      padding-bottom: 16px;
    }
  }
  /* Drop to 2 chips per row at very narrow widths so labels stay readable. */
  @media (max-width: 360px) {
    .pk-chip {
      flex: 1 1 calc(50% - 4px);
      font-size: 11px;
      padding: 10px 8px;
    }
  }
</style>
