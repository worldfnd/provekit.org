---
import Panel from '~/components/panel/Panel.astro';
import ArrowRight from '~/components/icons/ArrowRight.astro';
---

<!-- Interactive proof-graph banner (canvas particle simulation + animated CSS blooms).
     Ported from the canonical ProveKit Landing.html — Hero+InteractiveBanner JSX. -->
<div
  data-pk-hero-banner
  class="pk-hero-banner"
  aria-hidden="true"
  style="position:relative;width:1600px;max-width:100%;height:600px;overflow:hidden;background:#fff;border-left:1px solid var(--pk-line);border-right:1px solid var(--pk-line)"
>
  <!-- Pastel bloom backdrop (peach → lavender → sky blue) -->
  <div class="pk-hero-blooms">
    <div class="pk-hero-grad"></div>
    <div class="pk-hero-bloom pk-hero-bloom-a"></div>
    <div class="pk-hero-bloom pk-hero-bloom-b"></div>
    <div class="pk-hero-bloom pk-hero-bloom-c"></div>
    <div class="pk-hero-bloom pk-hero-bloom-d"></div>
    <div class="pk-hero-bloom pk-hero-bloom-e"></div>
    <div class="pk-hero-grain"></div>
  </div>

  <!-- Canvas web -->
  <canvas data-pk-hero-canvas class="pk-hero-canvas"></canvas>

  <!-- HUD readout follows cursor -->
  <div data-pk-hero-readout class="pk-hero-readout"><span>x:000 y:000</span></div>
</div>

<!-- Headline panel -->
<Panel
  tab="INTRODUCING PROVEKIT"
  tabBrand
  titleId="hero-title"
  contentStyle="padding:var(--pk-pad-panel-y) var(--pk-pad-panel-x);display:flex;flex-direction:column;gap:48px"
>
  <div class="pk-reveal">
    <h1
      id="hero-title"
      class="pk-display-headline"
      style="margin:0;font:500 72px/80px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink);white-space:pre-line"
    >
      {'Client-side zero-knowledge,\nbuilt for the real world'}
    </h1>
    <p
      class="pk-sub-deck"
      style="margin:16px 0 0;max-width:720px;font:300 24px/32px var(--pk-font-sans);color:var(--pk-mute)"
    >
      Turn a Noir circuit into a proof your users generate on their own device. Verify it
      anywhere you need to, from a server to a browser tab to a smart contract.
    </p>
  </div>
  <div class="pk-reveal pk-row-stack" style="display:flex;gap:24px;flex-wrap:wrap">
    <a
      href="https://github.com/worldfnd/provekit"
      class="pk-btn pk-btn--secondary"
      style="height:52px;padding:8px 16px;min-width:208px"
      target="_blank"
      rel="noopener"
    >
      VISIT REPO
      <span style="font:400 22px/1 var(--pk-font-mono);letter-spacing:0.02em">{'{ }'}</span>
    </a>
    <a
      href="https://docs.provekit.atheon.xyz/"
      class="pk-btn pk-btn--primary"
      style="height:52px;padding:8px 16px;min-width:237px"
      target="_blank"
      rel="noopener"
    >
      EXPLORE DOCS
      <ArrowRight />
    </a>
  </div>
</Panel>

<style>
  .pk-hero-banner {
    cursor: none;
  }
  .pk-hero-blooms {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    filter: blur(40px);
    opacity: 0.55;
  }
  .pk-hero-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top right, #fdcc91 0%, #ffb89a 45%, #ff9aa0 100%);
  }
  .pk-hero-bloom {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }
  .pk-hero-bloom-a {
    left: -10%;
    top: -30%;
    width: 820px;
    height: 820px;
    background: radial-gradient(circle, #ffe0bf 0%, transparent 70%);
    filter: blur(100px);
    opacity: 0.6;
    animation: pk-bloom-a 18s ease-in-out infinite alternate;
  }
  .pk-hero-bloom-b {
    left: 58%;
    top: -25%;
    width: 640px;
    height: 640px;
    background: radial-gradient(circle, #ff9aa0 0%, transparent 75%);
    filter: blur(110px);
    opacity: 0.55;
    animation: pk-bloom-b 22s ease-in-out infinite alternate;
  }
  .pk-hero-bloom-c {
    left: 35%;
    top: 30%;
    width: 720px;
    height: 720px;
    background: radial-gradient(circle, #fdcc91 0%, transparent 70%);
    filter: blur(130px);
    opacity: 0.55;
    animation: pk-bloom-c 26s ease-in-out infinite alternate;
  }
  .pk-hero-bloom-d {
    left: 75%;
    top: 45%;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, #ffb7b0 0%, transparent 72%);
    filter: blur(100px);
    opacity: 0.55;
    animation: pk-bloom-d 20s ease-in-out infinite alternate;
  }
  .pk-hero-bloom-e {
    left: 5%;
    top: 55%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #fdcc91 0%, transparent 72%);
    filter: blur(95px);
    opacity: 0.6;
    animation: pk-bloom-e 24s ease-in-out infinite alternate;
  }
  .pk-hero-grain {
    position: absolute;
    inset: 0;
    background: url('/figma/grain-texture.png') center/cover;
    opacity: 0.12;
    mix-blend-mode: overlay;
  }
  .pk-hero-canvas {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: block;
  }
  .pk-hero-readout {
    position: absolute;
    left: 0;
    top: 0;
    pointer-events: none;
    font:
      400 11px/1 ui-monospace,
      'SF Mono',
      Menlo,
      monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0d74ff;
    background: rgb(255 255 255 / 0.92);
    border: 1px solid rgb(13 116 255 / 0.4);
    padding: 6px 8px;
    opacity: 0;
    will-change: transform, opacity;
    transition: opacity 0.2s ease;
  }
  @keyframes pk-bloom-a {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(60px, 40px) scale(1.15);
    }
  }
  @keyframes pk-bloom-b {
    from {
      transform: translate(0, 0) scale(1.05);
    }
    to {
      transform: translate(-50px, 70px) scale(1);
    }
  }
  @keyframes pk-bloom-c {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(-80px, -50px) scale(1.18);
    }
  }
  @keyframes pk-bloom-d {
    from {
      transform: translate(0, 0) scale(1.1);
    }
    to {
      transform: translate(40px, -60px) scale(1);
    }
  }
  @keyframes pk-bloom-e {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(70px, -30px) scale(1.12);
    }
  }

  @media (max-width: 720px) {
    .pk-hero-banner {
      height: 340px !important;
      cursor: auto;
    }
    /* Tighten blooms for mobile so the warm gradient reads behind the
     * white particle web instead of washing out at narrow widths. */
    .pk-hero-blooms {
      opacity: 0.95 !important;
      filter: blur(18px) !important;
    }
    .pk-hero-bloom-a {
      left: -15% !important;
      top: -25% !important;
      width: 340px !important;
      height: 340px !important;
      filter: blur(48px) !important;
      opacity: 0.75 !important;
    }
    .pk-hero-bloom-b {
      left: 40% !important;
      top: -15% !important;
      width: 280px !important;
      height: 280px !important;
      filter: blur(52px) !important;
      opacity: 0.7 !important;
    }
    .pk-hero-bloom-c {
      left: 5% !important;
      top: 30% !important;
      width: 320px !important;
      height: 320px !important;
      filter: blur(60px) !important;
      opacity: 0.7 !important;
    }
    .pk-hero-bloom-d {
      left: 60% !important;
      top: 40% !important;
      width: 260px !important;
      height: 260px !important;
      filter: blur(46px) !important;
      opacity: 0.7 !important;
    }
    .pk-hero-bloom-e {
      left: -10% !important;
      top: 55% !important;
      width: 240px !important;
      height: 240px !important;
      filter: blur(44px) !important;
      opacity: 0.75 !important;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pk-hero-bloom {
      animation: none !important;
    }
  }
</style>

<script>
  // Canvas-driven proof-graph particle simulation.
  // Direct port of InteractiveBanner from the canonical ProveKit Landing HTML.
  interface Node {
    x: number;
    y: number;
    vx: number;
    vy: number;
    r: number;
    phase: number;
  }
  interface State {
    mx: number;
    my: number;
    tx: number;
    ty: number;
    active: boolean;
    click: number;
    clickX: number;
    clickY: number;
    t0: number;
  }

  document.querySelectorAll<HTMLElement>('[data-pk-hero-banner]').forEach((wrap) => {
    const canvas = wrap.querySelector<HTMLCanvasElement>('[data-pk-hero-canvas]');
    const readout = wrap.querySelector<HTMLElement>('[data-pk-hero-readout]');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const isMobile = window.matchMedia('(max-width: 720px)').matches;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0;
    let H = 0;
    let nodes: Node[] = [];

    const state: State = {
      mx: -9999,
      my: -9999,
      tx: -9999,
      ty: -9999,
      active: false,
      click: 0,
      clickX: 0,
      clickY: 0,
      t0: performance.now(),
    };

    const LINK = isMobile ? 110 : 150;
    const CURSOR_R = isMobile ? 150 : 240;
    const PHYSICS_R = isMobile ? 110 : 160;
    const PHYSICS_F = isMobile ? 0.45 : 0.55;
    const NODE_DENSITY = isMobile ? 4200 : 5500;
    const NODE_MIN = isMobile ? 70 : 160;
    const HUB_R = isMobile ? 1.8 : 2.2;
    const REG_R = isMobile ? 1.0 : 1.2;

    function seed() {
      const COUNT = Math.max(NODE_MIN, Math.floor((W * H) / NODE_DENSITY));
      nodes = [];
      for (let i = 0; i < COUNT; i++) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 0.18,
          vy: (Math.random() - 0.5) * 0.18,
          r: Math.random() < 0.08 ? HUB_R : REG_R,
          phase: Math.random() * Math.PI * 2,
        });
      }
    }

    function resize() {
      // Use offsetWidth/offsetHeight — these return CSS layout pixels,
      // unaffected by any ancestor `zoom`. getBoundingClientRect returns
      // post-zoom rendered size which would mis-seed the particle density.
      W = Math.max(1, wrap.offsetWidth);
      H = Math.max(1, wrap.offsetHeight);
      canvas!.width = W * dpr;
      canvas!.height = H * dpr;
      canvas!.style.width = W + 'px';
      canvas!.style.height = H + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      seed();
    }
    resize();
    const ro = new ResizeObserver(resize);
    ro.observe(wrap);

    const hex = (v: number) => ('00' + Math.max(0, v | 0).toString(16)).slice(-3).toUpperCase();

    function tick(now: number) {
      const t = (now - state.t0) / 1000;
      state.tx += (state.mx - state.tx) * 0.16;
      state.ty += (state.my - state.ty) * 0.16;
      const mx = state.tx;
      const my = state.ty;

      // physics
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i]!;
        if (state.active) {
          const dx = n.x - mx;
          const dy = n.y - my;
          const d2 = dx * dx + dy * dy;
          if (d2 < PHYSICS_R * PHYSICS_R && d2 > 1) {
            const d = Math.sqrt(d2);
            const f = (1 - d / PHYSICS_R) * PHYSICS_F;
            n.vx += (dx / d) * f;
            n.vy += (dy / d) * f;
          }
        }
        n.vx *= 0.94;
        n.vy *= 0.94;
        n.x += n.vx + Math.sin(t * 0.4 + n.phase) * 0.06;
        n.y += n.vy + Math.cos(t * 0.32 + n.phase * 1.3) * 0.06;
        if (n.x < -20) n.x = W + 20;
        else if (n.x > W + 20) n.x = -20;
        if (n.y < -20) n.y = H + 20;
        else if (n.y > H + 20) n.y = -20;
      }

      // readout
      if (readout) {
        const firstChild = readout.firstChild as HTMLElement | null;
        readout.style.opacity = state.active ? '1' : '0';
        readout.style.transform = `translate3d(${mx + 16}px, ${my + 16}px, 0)`;
        if (firstChild) firstChild.textContent = `x:${hex(mx)}  y:${hex(my)}`;
      }

      ctx!.clearRect(0, 0, W, H);

      // click pulse — expanding sweep bands
      let pulseR = -1;
      let pulseStrength = 0;
      if (state.click > 0) {
        const age = (now - state.click) / 1000;
        if (age < 1.4) {
          pulseR = age * 560;
          pulseStrength = 1 - age / 1.4;
          ctx!.strokeStyle = `rgba(255,255,255,${0.8 * pulseStrength})`;
          ctx!.lineWidth = 5;
          ctx!.beginPath();
          ctx!.moveTo(0, state.clickY - pulseR);
          ctx!.lineTo(W, state.clickY - pulseR);
          ctx!.moveTo(0, state.clickY + pulseR);
          ctx!.lineTo(W, state.clickY + pulseR);
          ctx!.moveTo(state.clickX - pulseR, 0);
          ctx!.lineTo(state.clickX - pulseR, H);
          ctx!.moveTo(state.clickX + pulseR, 0);
          ctx!.lineTo(state.clickX + pulseR, H);
          ctx!.stroke();
        } else {
          state.click = 0;
        }
      }

      // link web — solid + dashed mix, brand-blue tint near cursor + pulse
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i]!;
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j]!;
          const dx = b.x - a.x;
          const dy = b.y - a.y;
          const d2 = dx * dx + dy * dy;
          if (d2 > LINK * LINK) continue;
          const d = Math.sqrt(d2);
          const proximity = 1 - d / LINK;
          let cursorBoost = 0;
          if (state.active) {
            const mxd = (a.x + b.x) * 0.5 - mx;
            const myd = (a.y + b.y) * 0.5 - my;
            const cd = Math.hypot(mxd, myd);
            if (cd < CURSOR_R) cursorBoost = 1 - cd / CURSOR_R;
          }
          let pulseBoost = 0;
          if (pulseR > 0) {
            const midX = (a.x + b.x) * 0.5;
            const midY = (a.y + b.y) * 0.5;
            const md = Math.min(
              Math.abs(midY - (state.clickY - pulseR)),
              Math.abs(midY - (state.clickY + pulseR)),
              Math.abs(midX - (state.clickX - pulseR)),
              Math.abs(midX - (state.clickX + pulseR)),
            );
            if (md < 60) pulseBoost = (1 - md / 60) * pulseStrength;
          }
          const baseAlpha = 0.22 * proximity;
          const blueAlpha = (0.85 * cursorBoost + 0.95 * pulseBoost) * proximity;
          const edgeKey = i * 131 + j * 17;
          const isDashed = edgeKey % 3 === 0;
          ctx!.save();
          ctx!.setLineDash(isDashed ? [10, 8] : []);
          if (blueAlpha > 0.01) {
            ctx!.strokeStyle = `rgba(255,255,255,${Math.min(1, blueAlpha + baseAlpha * 0.6 + 0.25)})`;
            ctx!.lineWidth = (isMobile ? 2.2 : 4.2) + cursorBoost * (isMobile ? 1.2 : 1.8);
          } else {
            ctx!.strokeStyle = `rgba(255,255,255,${Math.min(1, baseAlpha * 2.6 + 0.5)})`;
            ctx!.lineWidth = isMobile ? 1.6 : 3.2;
          }
          ctx!.beginPath();
          ctx!.moveTo(a.x, a.y);
          ctx!.lineTo(b.x, b.y);
          ctx!.stroke();
          ctx!.restore();
        }
      }

      // cursor-to-node tendrils
      if (state.active) {
        for (let i = 0; i < nodes.length; i++) {
          const n = nodes[i]!;
          const ddx = n.x - mx;
          const ddy = n.y - my;
          const d = Math.hypot(ddx, ddy);
          if (d < CURSOR_R) {
            const aA = 0.85 * (1 - d / CURSOR_R);
            ctx!.strokeStyle = `rgba(255,255,255,${aA})`;
            ctx!.lineWidth = isMobile ? 1.8 : 3.4;
            ctx!.beginPath();
            ctx!.moveTo(mx, my);
            ctx!.lineTo(n.x, n.y);
            ctx!.stroke();
          }
        }
      }

      // nodes (square)
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i]!;
        let near = 0;
        if (state.active) {
          const d = Math.hypot(n.x - mx, n.y - my);
          if (d < CURSOR_R) near = 1 - d / CURSOR_R;
        }
        if (near > 0.15 || n.r > 1.5) {
          ctx!.fillStyle = `rgba(255,255,255,${0.15 + near * 0.25})`;
          const haloSize = n.r + (isMobile ? 4 : 6) + near * (isMobile ? 3 : 5);
          ctx!.fillRect(n.x - haloSize, n.y - haloSize, haloSize * 2, haloSize * 2);
        }
        ctx!.fillStyle =
          near > 0.1
            ? `rgba(255,255,255,${0.9 + near * 0.1})`
            : n.r > 1.5
              ? 'rgba(255,255,255,0.85)'
              : 'rgba(255,255,255,0.7)';
        const sz = n.r * 2;
        ctx!.fillRect(n.x - sz / 2, n.y - sz / 2, sz, sz);
      }

      // cursor crosshair (desktop only)
      if (state.active && !isMobile) {
        ctx!.save();
        ctx!.setLineDash([3, 5]);
        ctx!.strokeStyle = 'rgba(255,255,255,0.85)';
        ctx!.lineWidth = 1.8;
        ctx!.beginPath();
        ctx!.moveTo(mx, 0);
        ctx!.lineTo(mx, H);
        ctx!.stroke();
        ctx!.beginPath();
        ctx!.moveTo(0, my);
        ctx!.lineTo(W, my);
        ctx!.stroke();
        ctx!.setLineDash([2, 6]);
        ctx!.strokeStyle = 'rgba(255,255,255,0.35)';
        ctx!.lineWidth = 1.2;
        for (const dx of [-90, 90]) {
          ctx!.beginPath();
          ctx!.moveTo(mx + dx, 0);
          ctx!.lineTo(mx + dx, H);
          ctx!.stroke();
        }
        for (const dy of [-60, 60]) {
          ctx!.beginPath();
          ctx!.moveTo(0, my + dy);
          ctx!.lineTo(W, my + dy);
          ctx!.stroke();
        }
        ctx!.restore();
        ctx!.strokeStyle = 'rgba(255,255,255,0.8)';
        ctx!.lineWidth = 1.8;
        for (let i = -3; i <= 3; i++) {
          if (i === 0) continue;
          const tx = mx + i * 28;
          ctx!.beginPath();
          ctx!.moveTo(tx, my - 4);
          ctx!.lineTo(tx, my + 4);
          ctx!.stroke();
          const ty = my + i * 28;
          ctx!.beginPath();
          ctx!.moveTo(mx - 4, ty);
          ctx!.lineTo(mx + 4, ty);
          ctx!.stroke();
        }
        ctx!.fillStyle = 'rgba(255,255,255,1)';
        ctx!.fillRect(mx - 3, my - 3, 6, 6);
        ctx!.strokeStyle = 'rgba(255,255,255,0.95)';
        ctx!.lineWidth = 1.2;
        ctx!.strokeRect(mx - 6, my - 6, 12, 12);
      }

      raf = requestAnimationFrame(tick);
    }

    let raf = requestAnimationFrame(tick);

    function getPoint(e: MouseEvent | TouchEvent): { x: number; y: number } | null {
      // Translate viewport coords → canvas CSS-pixel coords. Under CSS `zoom`,
      // getBoundingClientRect returns post-zoom rendered size, so we scale the
      // delta by (offsetWidth / boundingRect.width) to land back in CSS px.
      const r = wrap.getBoundingClientRect();
      const sx = r.width === 0 ? 1 : wrap.offsetWidth / r.width;
      const sy = r.height === 0 ? 1 : wrap.offsetHeight / r.height;
      if ('touches' in e) {
        const t = e.touches[0] || e.changedTouches[0];
        if (!t) return null;
        return { x: (t.clientX - r.left) * sx, y: (t.clientY - r.top) * sy };
      }
      return {
        x: ((e as MouseEvent).clientX - r.left) * sx,
        y: ((e as MouseEvent).clientY - r.top) * sy,
      };
    }

    function onMove(e: MouseEvent | TouchEvent) {
      const p = getPoint(e);
      if (!p) return;
      if (!state.active) {
        state.tx = p.x;
        state.ty = p.y;
      }
      state.mx = p.x;
      state.my = p.y;
      state.active = true;
    }
    function onLeave() {
      state.active = false;
      state.mx = -9999;
      state.my = -9999;
    }
    function onClick(e: MouseEvent | TouchEvent) {
      const p = getPoint(e);
      if (!p) return;
      state.clickX = p.x;
      state.clickY = p.y;
      state.click = performance.now();
    }

    wrap.addEventListener('mousemove', onMove);
    wrap.addEventListener('mouseleave', onLeave);
    wrap.addEventListener('click', onClick);
    wrap.addEventListener('touchstart', (e) => {
      onMove(e);
      onClick(e);
    });
    wrap.addEventListener('touchmove', onMove);
    wrap.addEventListener('touchend', onLeave);
  });
</script>
