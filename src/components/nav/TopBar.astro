---
import ArrowRight from '~/components/icons/ArrowRight.astro';

const DOCS_URL = 'https://docs.provekit.org/';
const INSTALL_URL = `${DOCS_URL}getting-started/installation/`;

const NAV_ITEMS = [
  { num: '01', label: 'Home', href: '/', meta: 'The landing page' },
  { num: '02', label: 'Benchmarks', href: '/benchmarks', meta: 'Compare performance' },
  {
    num: '03',
    label: 'Documentation',
    href: DOCS_URL,
    meta: 'Guides & API reference',
  },
  {
    num: '04',
    label: 'GitHub',
    href: 'https://github.com/worldfnd/provekit',
    meta: 'Source on GitHub',
    external: true,
  },
  { num: '05', label: 'Contact', href: 'mailto:remco@world.org', meta: 'Reach the team' },
];
---

<header class="pk-topbar">
  <div class="pk-topbar-inner">
    <div class="pk-topbar-brand">
      <a href="/" aria-label="ProveKit home" style="display:block;line-height:0">
        <img
          src="/figma/wordmark-black.svg"
          alt="ProveKit"
          loading="eager"
          decoding="async"
          class="pk-topbar-wordmark"
        />
      </a>
    </div>
    <div class="pk-topbar-actions">
      <a
        href={DOCS_URL}
        class="pk-btn pk-btn--primary pk-topbar-docs"
        style="height:52px;padding-left:16px;padding-right:16px;width:auto;min-width:0"
      >
        DOCS
        <ArrowRight />
      </a>
      <button
        type="button"
        class="pk-topbar-menu-btn"
        data-nav-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="pk-nav-overlay"
      >
        <span class="pk-topbar-menu-icon" data-nav-icon-closed>
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="square"
            aria-hidden="true"
          >
            <path d="M3 6h18M3 12h18M3 18h18"></path>
          </svg>
        </span>
        <span class="pk-topbar-menu-icon" data-nav-icon-open hidden>
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="square"
            aria-hidden="true"
          >
            <path d="M5 5l14 14"></path>
            <path d="M19 5L5 19"></path>
          </svg>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Nav overlay (sits below the sticky header). Hidden by default, slides
     down when the hamburger toggles. Click outside or press Esc to close. -->
<div id="pk-nav-overlay" class="pk-nav-overlay" data-nav-overlay aria-hidden="true" hidden>
  <div class="pk-nav-backdrop" data-nav-close></div>
  <div class="pk-nav-sheet" role="dialog" aria-modal="true" aria-label="Site navigation">
    <div class="pk-nav-meta">
      <span>NAVIGATION · v1.0.0</span>
      <span class="pk-nav-meta-hide">PRESS ESC TO CLOSE</span>
      <span class="pk-nav-meta-show">TAP × TO CLOSE</span>
    </div>
    <!--email_off-->
    <nav class="pk-nav-list">
      {
        NAV_ITEMS.map((item, i) => (
          <a
            href={item.href}
            class="pk-nav-item"
            data-nav-close
            data-first={i === 0 ? '' : undefined}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener' : undefined}
          >
            <span class="pk-nav-num">{item.num}</span>
            <span class="pk-nav-label">{item.label}</span>
            <span class="pk-nav-meta-text">
              <span class="pk-nav-meta-copy">{item.meta}</span>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="square"
                aria-hidden="true"
              >
                <path d="M7 17L17 7M9 7h8v8" />
              </svg>
            </span>
          </a>
        ))
      }
    </nav>
    <!--/email_off-->
    <div class="pk-nav-cta">
      <span class="pk-nav-cta-label">GET STARTED</span>
      <a
        href={INSTALL_URL}
        class="pk-btn pk-btn--primary"
        style="height:52px;padding:8px 16px;min-width:240px"
        data-nav-close
      >
        INSTALL PROVEKIT
        <ArrowRight />
      </a>
    </div>
  </div>
</div>

<script>
  // Hamburger nav: toggle aria-expanded, slide the overlay, swap icons,
  // lock body scroll while open. Esc / click-outside / link-click closes.
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const overlay = document.querySelector<HTMLElement>('[data-nav-overlay]');
  const iconClosed = document.querySelector<HTMLElement>('[data-nav-icon-closed]');
  const iconOpen = document.querySelector<HTMLElement>('[data-nav-icon-open]');
  const menuBtn = document.querySelector<HTMLButtonElement>('.pk-topbar-menu-btn');

  let isOpen = false;
  let savedOverflow = '';

  function setOpen(next: boolean) {
    if (next === isOpen || !toggle || !overlay) return;
    isOpen = next;
    toggle.setAttribute('aria-expanded', String(next));
    toggle.setAttribute('aria-label', next ? 'Close menu' : 'Open menu');
    if (next) {
      overlay.hidden = false;
      overlay.setAttribute('aria-hidden', 'false');
      // Re-flow before applying open class so the transition runs.
      requestAnimationFrame(() => overlay.classList.add('is-open'));
      savedOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      iconClosed?.setAttribute('hidden', '');
      iconOpen?.removeAttribute('hidden');
      menuBtn?.classList.add('is-open');
    } else {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = savedOverflow;
      iconClosed?.removeAttribute('hidden');
      iconOpen?.setAttribute('hidden', '');
      menuBtn?.classList.remove('is-open');
      // Wait for the transition to finish before hiding from the a11y tree.
      window.setTimeout(() => {
        if (!isOpen && overlay) overlay.hidden = true;
      }, 420);
    }
  }

  toggle?.addEventListener('click', () => setOpen(!isOpen));
  overlay?.querySelectorAll<HTMLElement>('[data-nav-close]').forEach((el) => {
    el.addEventListener('click', () => setOpen(false));
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) setOpen(false);
  });
</script>

<style>
  .pk-topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    height: 76px;
    background: #fff;
    border-bottom: 1px solid var(--pk-line);
    display: flex;
    justify-content: center;
  }
  .pk-topbar-inner {
    width: 1600px;
    max-width: 100%;
    height: 100%;
    box-sizing: border-box;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-left: 1px solid var(--pk-line);
    border-right: 1px solid var(--pk-line);
  }
  .pk-topbar-brand {
    display: flex;
    align-items: center;
    padding: 0 24px;
    height: 48px;
    margin-left: 16px;
  }
  .pk-topbar-wordmark {
    height: 24px;
    display: block;
  }
  .pk-topbar-actions {
    display: flex;
    align-items: center;
    margin-right: 16px;
  }
  .pk-topbar-menu-btn {
    width: 56px;
    height: 52px;
    background: #fff;
    border: 1px solid var(--pk-line);
    border-left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--pk-ink);
    transition: background 0.25s ease;
  }
  .pk-topbar-menu-btn.is-open {
    background: var(--pk-ink);
    color: #fff;
  }
  /* Springy rotation when the menu toggles. */
  .pk-topbar-menu-icon svg {
    transition: transform 0.3s cubic-bezier(0.4, 1.4, 0.5, 1);
  }
  .pk-topbar-menu-btn.is-open .pk-topbar-menu-icon svg {
    transform: rotate(90deg);
  }

  /* Nav overlay */
  .pk-nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 40;
    pointer-events: none;
  }
  .pk-nav-overlay.is-open {
    pointer-events: auto;
  }
  .pk-nav-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(13 13 11 / 0.4);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .pk-nav-overlay.is-open .pk-nav-backdrop {
    opacity: 1;
  }
  .pk-nav-sheet {
    position: absolute;
    top: 76px;
    left: 50%;
    transform: translateX(-50%) translateY(-24px);
    width: min(1600px, calc(100vw - 2 * var(--pk-gutter)));
    max-height: calc(100vh - 76px);
    overflow-y: auto;
    background: #fff;
    border-left: 1px solid var(--pk-line);
    border-right: 1px solid var(--pk-line);
    border-bottom: 1px solid var(--pk-line);
    opacity: 0;
    transition:
      opacity 0.32s ease,
      transform 0.42s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .pk-nav-overlay.is-open .pk-nav-sheet {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .pk-nav-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 32px;
    border-bottom: 1px solid var(--pk-line);
    font: 400 12px/1 var(--pk-font-mono);
    letter-spacing: 0.12em;
    color: #808080;
  }
  .pk-nav-meta-show {
    display: none;
  }
  .pk-nav-list {
    padding: 8px 32px 24px;
    display: flex;
    flex-direction: column;
  }
  .pk-nav-item {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    align-items: center;
    gap: 24px;
    padding: 20px 0;
    border-top: 1px solid var(--pk-line);
    color: inherit;
    text-decoration: none;
    transition: background 0.18s ease;
  }
  .pk-nav-item[data-first] {
    border-top: 0;
  }
  .pk-nav-num {
    font: 400 14px/1 var(--pk-font-mono);
    letter-spacing: 0.08em;
    color: #808080;
    transition: color 0.2s ease;
  }
  .pk-nav-label {
    font: 500 56px/1 var(--pk-font-sans);
    letter-spacing: -0.02em;
    color: var(--pk-ink);
    transition:
      color 0.2s ease,
      transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .pk-nav-meta-text {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font: 400 14px/1 var(--pk-font-mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #808080;
  }
  .pk-nav-item:hover .pk-nav-num,
  .pk-nav-item:hover .pk-nav-label {
    color: var(--pk-brand);
  }
  .pk-nav-item:hover .pk-nav-label {
    transform: translateX(12px);
  }
  .pk-nav-item:hover .pk-nav-meta-text {
    color: var(--pk-ink);
  }
  .pk-nav-item:hover .pk-nav-meta-text svg {
    stroke: var(--pk-brand);
    transform: translate(8px, -8px);
  }
  .pk-nav-meta-text svg {
    transition:
      transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
      stroke 0.2s ease;
    stroke: var(--pk-ink);
  }

  .pk-nav-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding: 24px 32px 32px;
    border-top: 1px solid var(--pk-line);
  }
  .pk-nav-meta-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pk-nav-meta-tab {
    font: 400 12px/1 var(--pk-font-mono);
    letter-spacing: 0.12em;
    color: #808080;
  }
  .pk-nav-meta-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pk-nav-meta-link {
    font: 400 18px/1.2 var(--pk-font-sans);
    color: var(--pk-ink);
    text-decoration: none;
    display: inline-block;
    position: relative;
    padding-bottom: 2px;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition:
      background-size 0.25s ease,
      color 0.2s ease;
  }
  .pk-nav-meta-link:hover {
    background-size: 100% 1px;
    color: var(--pk-brand);
  }

  .pk-nav-cta {
    padding: 20px 32px;
    border-top: 1px solid var(--pk-line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }
  .pk-nav-cta-label {
    font: 400 12px/1 var(--pk-font-mono);
    letter-spacing: 0.12em;
    color: #808080;
  }

  @media (min-width: 721px) and (max-width: 1199px) {
    .pk-topbar-inner {
      width: 100%;
    }
    .pk-topbar-brand {
      margin-left: 0;
    }
    .pk-topbar-actions {
      margin-right: 0;
    }
    .pk-nav-label {
      font-size: 40px;
    }
  }

  @media (max-width: 720px) {
    .pk-topbar {
      height: 56px;
    }
    .pk-topbar-brand {
      padding: 0 16px;
      margin-left: 0;
    }
    .pk-topbar-wordmark {
      height: 18px;
    }
    .pk-topbar-docs {
      height: 56px !important;
      font: 400 13px/1 var(--pk-font-mono) !important;
      padding: 0 14px !important;
    }
    .pk-topbar-menu-btn {
      width: 44px;
      height: 56px;
    }
    .pk-topbar-actions {
      margin-right: 0;
      height: 56px;
    }

    .pk-nav-sheet {
      top: 56px;
      width: 100vw;
      max-width: 430px;
      max-height: calc(100vh - 56px);
      border-left: 0;
      border-right: 0;
    }
    .pk-nav-meta {
      padding: 12px 16px;
      font-size: 10px;
      letter-spacing: 0.14em;
    }
    .pk-nav-meta-hide {
      display: none;
    }
    .pk-nav-meta-show {
      display: inline;
    }
    .pk-nav-list {
      padding: 0 16px;
    }
    .pk-nav-item {
      grid-template-columns: 40px 1fr 20px;
      gap: 12px;
      padding: 18px 0;
    }
    .pk-nav-num {
      font-size: 12px;
    }
    .pk-nav-label {
      font-size: 34px;
    }
    .pk-nav-meta-copy {
      display: none;
    }
    .pk-nav-meta-text svg {
      width: 16px;
      height: 16px;
    }
    .pk-nav-meta-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 20px 16px;
    }
    .pk-nav-meta-link {
      font-size: 15px;
    }
    .pk-nav-cta {
      padding: 16px;
      flex-direction: column;
      align-items: stretch;
    }
    .pk-nav-cta-label {
      display: none;
    }
    .pk-nav-cta .pk-btn {
      width: 100% !important;
    }
  }
</style>
