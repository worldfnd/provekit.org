---
import Panel from '~/components/panel/Panel.astro';

const cells = [
  { label: 'Hardware', value: 'MacBook Air', sub: 'Apple M2 · 16 GB' },
  { label: 'Circuit', value: 'SHA-256', sub: 'preimage proof · 52,029 R1CS constraints' },
  { label: 'Systems', value: '3 stacks', sub: 'WHIR · UltraHonk · Groth16 (rapidsnark)' },
  { label: 'Setup', value: '2.86 s', sub: 'one-time prepare · no ceremony' },
  { label: 'Branch', value: 'v1.0.0', sub: 'audited release line' },
];
---

<Panel
  tab="METHODOLOGY"
  titleId="methodology-title"
  contentStyle="display:flex;flex-direction:column"
>
  <div class="pk-methodology-head" style="padding:var(--pk-pad-panel-x) var(--pk-pad-panel-x) 0">
    <h2
      id="methodology-title"
      class="pk-reveal pk-methodology-title"
      style="margin:0;font:500 48px/56px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink)"
    >
      How these numbers were captured
    </h2>
    <p
      class="pk-reveal"
      style="margin:16px 0 0;max-width:880px;font:300 20px/1.4 var(--pk-font-sans);color:var(--pk-mute-2)"
    >
      All three toolkits prove the same SHA-256 preimage statement on the same MacBook Air (Apple
      M2, 16 GB). Timings are full wall clock including witness generation; memory is peak resident
      set. ProveKit figures reflect the audited v1 branch. Circom is measured with native
      rapidsnark.
    </p>
  </div>
  <div
    class="pk-methodology-cells"
    style="display:flex;margin-top:48px;border-top:1px solid var(--pk-line);flex-wrap:wrap"
  >
    {
      cells.map((c, i) => (
        <div
          class="pk-methodology-cell"
          style={`flex:1 1 0;min-width:200px;padding:32px 24px;${i < cells.length - 1 ? 'border-right:1px solid var(--pk-line);' : ''}display:flex;flex-direction:column;gap:8px`}
        >
          <div style="font:400 14px/1 var(--pk-font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--pk-mute-2)">
            {c.label}
          </div>
          <div style="font:500 32px/1.1 var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink)">
            {c.value}
          </div>
          <div style="font:300 16px/1.4 var(--pk-font-sans);color:var(--pk-mute-2)">{c.sub}</div>
        </div>
      ))
    }
  </div>
</Panel>

<style>
  @media (max-width: 720px) {
    .pk-methodology-title {
      font: 500 28px/32px var(--pk-font-sans) !important;
    }
    .pk-methodology-head p {
      font-size: 14px !important;
      line-height: 1.45 !important;
    }
    /* Stack cells vertically so labels never wrap character-by-character. */
    .pk-methodology-cells {
      flex-direction: column !important;
    }
    .pk-methodology-cell {
      min-width: 0 !important;
      padding: 18px 20px !important;
      border-right: 0 !important;
      border-bottom: 1px solid var(--pk-line);
    }
    .pk-methodology-cell:last-child {
      border-bottom: 0;
    }
    .pk-methodology-cell > div:nth-child(2) {
      font-size: 22px !important;
    }
    .pk-methodology-cell > div:nth-child(3) {
      font-size: 13px !important;
    }
  }
</style>
