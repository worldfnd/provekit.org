---
const series = [
  { key: 'toolkit1', label: 'TOOLKIT 1', color: 'var(--color-toolkit-1)' },
  { key: 'toolkit2', label: 'TOOLKIT 2', color: 'var(--color-toolkit-2)' },
  { key: 'provekit', label: 'PROVEKIT', color: 'var(--color-toolkit-3)' },
] as const;

// One bar per metric, in the toolkit colour assigned to that metric (from Figma).
const bars = [
  { metric: 'METRIC 1', width: 28, color: 'var(--color-toolkit-1)' },
  { metric: 'METRIC 2', width: 60, color: 'var(--color-toolkit-2)' },
  { metric: 'METRIC 3', width: 92, color: 'var(--color-toolkit-3)' },
];
---

<figure class="space-y-8" aria-labelledby="bench-chart-label">
  <figcaption id="bench-chart-label" class="sr-only">
    Illustrative benchmark comparison; longer bars are better. {
      bars.map((b) => `${b.metric.toLowerCase()} bar reaches ${b.width}%`).join('. ')
    }. Numbers are illustrative until full methodology is published.
  </figcaption>

  <div class="flex flex-wrap items-center gap-3">
    {
      series.map((s) => (
        <span class="pk-eyebrow">
          <span class="mr-2 inline-block h-2 w-2 rounded-sm" style={`background:${s.color}`} />
          {s.label}
        </span>
      ))
    }
  </div>

  <div class="space-y-5" aria-hidden="true">
    {
      bars.map((b) => (
        <div class="flex items-center gap-4">
          <div class="h-4 flex-1 overflow-hidden rounded-sm bg-[color:var(--color-line-soft)]">
            <div class="h-full rounded-sm" style={`width:${b.width}%;background:${b.color}`} />
          </div>
          <span class="pk-mono w-20 text-xs text-[color:var(--color-mute)]">{b.metric}</span>
        </div>
      ))
    }
  </div>

  <p class="pk-mono text-[10px] text-[color:var(--color-mute)]">
    Illustrative until full methodology is published &mdash; see All Benchmarks.
  </p>
</figure>
