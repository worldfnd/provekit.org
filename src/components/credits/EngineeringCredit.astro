---
const partners = [
  { letter: 'W', name: 'world', href: '#' },
  { letter: 'A', name: 'atheon', href: '#' },
  { letter: 'R', name: 'reilabs', href: '#' },
];
---

<div class="grid gap-12 py-24 md:grid-cols-2 md:items-center">
  <div>
    <p class="pk-reveal"><span class="pk-eyebrow">BUILT FOR PERFORMANCE AND PRIVACY</span></p>
    <h2 id="credit-title" class="pk-h2 pk-reveal mt-4">
      Engineered by some of the best technical brains
    </h2>
    <ul class="pk-reveal mt-8 flex flex-wrap items-center gap-6" data-todo="partner-logos">
      {
        partners.map((p) => (
          <li>
            <a
              href={p.href}
              class="flex items-center gap-2 text-[color:var(--color-mute)] hover:text-[color:var(--color-ink)]"
            >
              <span class="pk-mono grid h-8 w-8 place-items-center rounded-full border border-[color:var(--color-line)] text-xs">
                {p.letter}
              </span>
              <span class="pk-mono text-sm">{p.name}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <a href="#" class="pk-btn pk-btn--primary pk-reveal mt-10" data-todo="github">
      Visit GitHub
      <span aria-hidden="true">→</span>
    </a>
  </div>

  <figure
    class="pk-reveal relative w-full justify-self-center md:justify-self-end"
    aria-hidden="true"
  >
    <img
      src="/figma/credit-art.png"
      alt=""
      width="1200"
      height="740"
      class="w-full rounded-md select-none"
      loading="lazy"
      decoding="async"
    />
  </figure>
</div>
