---
import Panel from '~/components/panel/Panel.astro';
import ArrowRight from '~/components/icons/ArrowRight.astro';
---

<Panel
  tab="BUILT FOR PERFORMANCE AND PRIVACY"
  titleId="credit-title"
  contentStyle="padding:var(--pk-pad-panel-y) var(--pk-pad-panel-x);display:flex;justify-content:flex-start;align-items:stretch;gap:48px;position:relative"
>
  <div
    class="pk-reveal"
    style="display:flex;flex-direction:column;gap:48px;position:relative;z-index:1;flex:1 1 0;min-width:0"
  >
    <h2
      id="credit-title"
      class="pk-display-headline"
      style="margin:0;font:500 72px/80px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink);white-space:pre-line"
    >
      {'Engineered by some of\nthe best technical brains'}
    </h2>
    <div class="pk-partner-row" data-pk-partners style="display:flex;align-items:center;gap:36px;flex-wrap:wrap">
      <div class="pk-partner-logo" data-partner-logo style="display:flex;align-items:center;height:48px;padding:0 16px;transition:filter 0.5s cubic-bezier(0.32,0.72,0,1),opacity 0.5s cubic-bezier(0.32,0.72,0,1),transform 0.5s cubic-bezier(0.32,0.72,0,1)">
        <img
          src="/figma/world-logo.svg"
          alt="World"
          loading="lazy"
          decoding="async"
          style="height:32px;width:auto;display:block;transform:translateY(4px);pointer-events:none"
        />
      </div>
      <div class="pk-partner-divider" data-partner-divider style="width:0;height:40px;border-left:2px solid var(--pk-line-soft);transition:opacity 0.5s cubic-bezier(0.32,0.72,0,1)" aria-hidden="true">
      </div>
      <div class="pk-partner-logo" data-partner-logo style="display:flex;align-items:center;height:48px;padding:0 16px;transition:filter 0.5s cubic-bezier(0.32,0.72,0,1),opacity 0.5s cubic-bezier(0.32,0.72,0,1),transform 0.5s cubic-bezier(0.32,0.72,0,1)">
        <img
          src="/figma/atheon-logo.svg"
          alt="Atheon"
          loading="lazy"
          decoding="async"
          style="height:36px;width:auto;display:block;pointer-events:none"
        />
      </div>
      <div class="pk-partner-divider" data-partner-divider style="width:0;height:40px;border-left:2px solid var(--pk-line-soft);transition:opacity 0.5s cubic-bezier(0.32,0.72,0,1)" aria-hidden="true">
      </div>
      <div class="pk-partner-logo" data-partner-logo style="display:flex;align-items:center;height:48px;padding:0 16px;transition:filter 0.5s cubic-bezier(0.32,0.72,0,1),opacity 0.5s cubic-bezier(0.32,0.72,0,1),transform 0.5s cubic-bezier(0.32,0.72,0,1)">
        <img
          src="/figma/reilabs-logo.svg"
          alt="Reilabs"
          loading="lazy"
          decoding="async"
          style="height:36px;width:auto;display:block;pointer-events:none"
        />
      </div>
      <div class="pk-partner-divider" data-partner-divider style="width:0;height:40px;border-left:2px solid var(--pk-line-soft);transition:opacity 0.5s cubic-bezier(0.32,0.72,0,1)" aria-hidden="true">
      </div>
      <div class="pk-partner-logo" data-partner-logo style="display:flex;align-items:center;height:48px;padding:0 16px;transition:filter 0.5s cubic-bezier(0.32,0.72,0,1),opacity 0.5s cubic-bezier(0.32,0.72,0,1),transform 0.5s cubic-bezier(0.32,0.72,0,1)">
        <img
          src="/figma/nethermind-logo.svg"
          alt="Nethermind"
          loading="lazy"
          decoding="async"
          style="height:28px;width:auto;display:block;pointer-events:none"
        />
      </div>
    </div>
    <div>
      <a
        href="https://github.com/worldfnd/provekit"
        class="pk-btn pk-btn--primary"
        style="height:52px;padding:8px 16px;min-width:237px"
        target="_blank"
        rel="noopener"
      >
        VISIT GITHUB
        <ArrowRight />
      </a>
    </div>
  </div>

  <img
    slot="extras"
    src="/figma/partners-graphic-v2.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
    decoding="async"
    class="pk-partners-bg"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;object-position:calc(100% + 8px) center;display:block;pointer-events:none"
  />
</Panel>

<style>
  @media (min-width: 721px) and (max-width: 1199px) {
    /* Keep background image hidden at tablet too – it overlaps the text at
     * narrower viewports where the flex column fills full width. */
    .pk-partners-bg {
      display: none !important;
    }
    .pk-partner-row {
      gap: 20px !important;
    }
    #credit-title {
      font-size: 38px !important;
      line-height: 1.15 !important;
      white-space: normal !important;
    }
  }

  @media (max-width: 720px) {
    .pk-partner-row {
      display: grid !important;
      grid-template-columns: 1fr 1fr;
      gap: 0 !important;
      border: 1px solid var(--pk-line);
    }
    .pk-partner-row > div[aria-hidden] {
      display: none;
    }
    /* Clean 2×2 grid: each cell gets bottom+right dividers, outer border
     * comes from the row. Avoids the negative-margin alignment glitches. */
    .pk-partner-logo {
      height: 64px !important;
      padding: 0 !important;
      justify-content: center;
      border: 0 !important;
      border-bottom: 1px solid var(--pk-line-soft) !important;
      border-right: 1px solid var(--pk-line-soft) !important;
      margin: 0 !important;
    }
    .pk-partner-logo:nth-of-type(2n) {
      border-right: 0 !important;
    }
    .pk-partner-logo:nth-last-of-type(-n + 2) {
      border-bottom: 0 !important;
    }
    .pk-partners-bg {
      display: none !important;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-pk-partners]').forEach((row) => {
    const logos = Array.from(row.querySelectorAll<HTMLElement>('[data-partner-logo]'));
    const dividers = Array.from(row.querySelectorAll<HTMLElement>('[data-partner-divider]'));

    logos.forEach((logo) => {
      logo.addEventListener('mouseenter', () => {
        logos.forEach((other) => {
          if (other === logo) {
            other.style.transform = 'scale(1.04)';
            other.style.filter = 'blur(0px)';
            other.style.opacity = '1';
          } else {
            other.style.transform = 'scale(1)';
            other.style.filter = 'blur(5px)';
            other.style.opacity = '0.35';
          }
        });
        dividers.forEach((d) => (d.style.opacity = '0.25'));
      });
    });

    row.addEventListener('mouseleave', () => {
      logos.forEach((logo) => {
        logo.style.transform = 'scale(1)';
        logo.style.filter = 'blur(0px)';
        logo.style.opacity = '1';
      });
      dividers.forEach((d) => (d.style.opacity = '1'));
    });
  });
</script>
