---
import Panel from '~/components/panel/Panel.astro';
import FeatureCard from './FeatureCard.astro';
---

<Panel
  tab="CORE FEATURES"
  titleId="features-title"
  contentClass="pk-feature-grid"
  contentStyle="padding:var(--pk-pad-panel-x);display:flex;gap:24px;justify-content:space-between;flex-wrap:wrap"
>
  <h2 id="features-title" class="sr-only">Core features</h2>
  <FeatureCard
    num="1"
    title="Modularity"
    borderColor="#BCEEFF"
    image="/figma/feature-modularity.png"
    body="Proving, verification, and compilation are separate, swappable pieces. Use the parts you need, drop the ones you don't, and keep the same proof artifacts working everywhere."
  />
  <FeatureCard
    num="2"
    title="Mobile friendly"
    borderColor="#FFE5C6"
    image="/figma/feature-mobile.png"
    body="Proofs are generated right on the user's device, whether a phone, a browser tab, or a laptop. Private data never has to leave it, and no heavy backend is required."
  />
  <FeatureCard
    num="3"
    title="Light weight"
    borderColor="#FFDEE7"
    image="/figma/feature-lightweight.png"
    body="Built in Rust with optimized field arithmetic, Provekit keeps resource usage minimal so it runs efficiently even on constrained hardware."
  />
</Panel>

<style>
  @media (min-width: 721px) and (max-width: 1199px) {
    /* Two columns at mid-tablet, single column at small tablet */
    .pk-feature-grid {
      gap: 20px !important;
    }
    /* Each card grows to fill available space but caps at ~50% so two fit per row */
    .pk-feature-grid > :global(*) {
      flex: 1 1 calc(50% - 12px);
      min-width: 260px;
    }
  }

  @media (min-width: 721px) and (max-width: 899px) {
    /* Single column on small tablets */
    .pk-feature-grid {
      flex-direction: column !important;
      gap: 16px !important;
    }
    .pk-feature-grid > :global(*) {
      flex: none;
      width: 100%;
      min-width: 0;
    }
  }

  @media (max-width: 720px) {
    .pk-feature-grid {
      flex-direction: column !important;
      gap: 16px !important;
    }
  }
</style>
