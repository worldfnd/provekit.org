---
interface Props {
  num: string;
  title: string;
  body: string;
  image: string;
  borderColor: string;
}
const { num, title, body, image, borderColor } = Astro.props;
---

<article
  class="pk-reveal pk-feature-card"
  style={`flex:1 1 0;max-width:465px;height:722px;border:2px solid ${borderColor};background:#fff;display:flex;flex-direction:column;overflow:hidden;position:relative`}
>
  <!-- Image area -->
  <div class="pk-feature-image" style="flex:1;position:relative;overflow:hidden;background:#fff">
    <img
      class="pk-feature-card__img"
      src={image}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;will-change:transform;transition:transform 700ms cubic-bezier(0.2,0.8,0.2,1)"
    />
  </div>
  <!-- Number + title bar -->
  <div
    class="pk-feature-titlebar"
    style={`display:flex;align-items:stretch;border-top:2px solid ${borderColor}`}
  >
    <div
      class="pk-feature-num"
      style={`width:69px;height:69px;display:flex;align-items:center;justify-content:center;border-right:1px solid ${borderColor};font:400 24px/1 var(--pk-font-mono);letter-spacing:0.02em`}
    >
      {num}
    </div>
    <h3
      class="pk-feature-title"
      style="flex:1;margin:0;display:flex;align-items:center;padding:0 24px;font:400 24px/1 var(--pk-font-mono);letter-spacing:0.02em;text-transform:uppercase;color:var(--pk-ink)"
    >
      {title}
    </h3>
  </div>
  <!-- Body -->
  <div
    class="pk-feature-body"
    style={`height:220px;padding:48px;border-top:2px solid ${borderColor};font:300 22px/1.4 var(--pk-font-sans);color:var(--pk-mute-2);box-sizing:border-box;display:flex;align-items:center`}
  >
    {body}
  </div>
</article>

<style>
  /* Hover lift on the image: tilts -4deg and scales 1.08 over 700ms ease.
   * Canonical ProveKit Landing.html FeatureCard interaction. */
  .pk-feature-card:hover .pk-feature-card__img {
    transform: rotate(-4deg) scale(1.08);
  }

  @media (min-width: 721px) and (max-width: 1199px) {
    .pk-feature-card {
      max-width: 100% !important;
      height: auto !important;
    }
    .pk-feature-image {
      flex: none !important;
      height: 260px !important;
    }
    .pk-feature-body {
      height: auto !important;
      padding: 28px 24px !important;
      font: 300 16px/1.45 var(--pk-font-sans) !important;
    }
  }

  @media (max-width: 720px) {
    .pk-feature-card {
      max-width: 100% !important;
      height: auto !important;
      flex: 1 1 100% !important;
    }
    .pk-feature-image {
      flex: none !important;
      height: 220px !important;
    }
    .pk-feature-num {
      width: 48px !important;
      height: 48px !important;
      font-size: 14px !important;
      letter-spacing: 0.04em !important;
    }
    .pk-feature-title {
      padding: 0 14px !important;
      font-size: 13px !important;
      letter-spacing: 0.04em !important;
    }
    .pk-feature-body {
      height: auto !important;
      padding: 18px 16px !important;
      font: 300 14px/1.45 var(--pk-font-sans) !important;
    }
  }
</style>
