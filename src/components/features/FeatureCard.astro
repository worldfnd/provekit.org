---
interface Props {
  index: string;
  title: string;
  body: string;
  art: 'modularity' | 'mobile' | 'lightweight';
}
const { index, title, body, art } = Astro.props;

const artMap = {
  modularity: '/figma/feature-modularity.png',
  mobile: '/figma/feature-mobile.png',
  lightweight: '/figma/feature-lightweight.png',
};
---

<article
  class="pk-reveal relative flex h-full flex-col gap-6 rounded-md border border-[color:var(--color-line)] bg-white p-8"
>
  <img
    src={artMap[art]}
    alt=""
    aria-hidden="true"
    width="930"
    height="792"
    class="aspect-[930/792] w-full rounded object-cover select-none"
    loading="lazy"
    decoding="async"
  />

  <div class="flex items-baseline gap-3">
    <span class="pk-mono text-xs" style="color:var(--color-brand)">{index}</span>
    <h3 class="pk-mono text-sm tracking-[0.12em]">{title}</h3>
  </div>
  <p class="pk-body text-base">{body}</p>
</article>
