---
/*
 * LiveDemoSection — panel chrome + React island mount point.
 *
 * Mirrors the bordered-panel + category-tab structure used everywhere else
 * in the design (Hero, Install, Features, etc.) and hosts the LiveDemo
 * React island via `client:visible` so the bundle only loads when the
 * section scrolls into view.
 */
import LiveDemo from './LiveDemo.tsx';
---

<section
  class="pk-demo-panel"
  aria-labelledby="demo-title"
  style="position:relative;width:1600px;max-width:100%;background:#fff;border:1px solid var(--pk-line)"
>
  <div class="pk-tab pk-tab--brand" style="border-top:0;border-left:0">
    LIVE DEMO
  </div>

  <h2 id="demo-title" class="sr-only">
    Run a zero-knowledge proof in your browser
  </h2>

  <LiveDemo client:visible />
</section>

<style is:global>
  /* Two-column desktop split (left inputs + CTA, right execution trace).
   * Below 1100px the trace stacks under the inputs to match the mobile
   * MobileDemo layout. */
  .pk-demo-panel .pk-live-demo {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }
  .pk-demo-panel .pk-live-demo__left {
    padding: 72px 48px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .pk-demo-panel .pk-live-demo__right {
    border-left: 1px solid var(--pk-line);
    display: flex;
    flex-direction: column;
    background: #fff;
  }
  .pk-demo-panel .pk-live-demo__trace-head {
    padding: 16px 24px;
    border-bottom: 1px solid var(--pk-line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font: 400 11px/1 var(--pk-font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pk-mute-2);
  }

  @media (max-width: 1100px) {
    .pk-demo-panel .pk-live-demo {
      grid-template-columns: minmax(0, 1fr);
    }
    .pk-demo-panel .pk-live-demo__right {
      border-left: 0;
      border-top: 1px solid var(--pk-line);
    }
    .pk-demo-panel .pk-live-demo__left {
      padding: 48px 32px;
      gap: 24px;
    }
  }
</style>
