---
interface Props {
  q: string;
  a?: string | undefined;
  open?: boolean | undefined;
}
const { q, a, open = false } = Astro.props;
---

<div class={`pk-faq-row${open ? ' is-open' : ''}`} data-pk-faq>
  <div
    class="pk-faq-summary"
    role="button"
    tabindex="0"
    aria-expanded={open ? 'true' : 'false'}
    data-pk-faq-trigger
  >
    <h3 class="pk-faq-q">{q}</h3>
    <span class="pk-faq-glyph" aria-hidden="true">+</span>
  </div>
  <div class="pk-faq-panel" data-pk-faq-panel>
    <div class="pk-faq-panel-inner">
      {a ? <p class="pk-faq-a">{a}</p> : <p class="pk-faq-a pk-faq-a-empty">Answer coming soon.</p>}
    </div>
  </div>
</div>

<style is:global>
  .pk-faq-row .pk-faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    gap: 24px;
  }
  .pk-faq-q {
    margin: 0;
    font: 500 28px/1 var(--pk-font-sans);
    letter-spacing: -0.02em;
    color: var(--pk-ink-alt);
    flex: 1;
  }
  .pk-faq-glyph {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: 400 24px/1 var(--pk-font-mono);
    color: var(--pk-ink-alt);
    transition:
      transform 0.36s var(--pk-easing),
      color 0.2s ease;
    flex: none;
  }
  .pk-faq-row.is-open .pk-faq-glyph {
    transform: rotate(45deg);
  }
  .pk-faq-row:hover .pk-faq-glyph {
    color: var(--pk-brand);
  }

  /* Smooth CSS-only accordion: grid row tween from 0fr → 1fr. No JS
   * measurement, no max-height snapping, no double motions. */
  .pk-faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.42s var(--pk-easing),
      opacity 0.28s var(--pk-easing);
  }
  .pk-faq-row.is-open .pk-faq-panel {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  .pk-faq-panel-inner {
    min-height: 0;
    overflow: hidden;
  }
  .pk-faq-a {
    margin: 16px 0 0;
    font: 300 22px/1.4 var(--pk-font-sans);
    color: var(--pk-mute-2);
  }
  .pk-faq-a-empty {
    color: var(--pk-mute-3);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .pk-faq-row {
      border-top: 1px solid var(--pk-line);
    }
    .pk-faq-row .pk-faq-summary {
      padding: 16px 0;
      align-items: flex-start;
      gap: 12px;
    }
    .pk-faq-q {
      font: 500 16px/1.3 var(--pk-font-sans);
      letter-spacing: -0.01em;
    }
    .pk-faq-glyph {
      width: 24px;
      height: 24px;
      font: 400 16px/1 var(--pk-font-mono);
    }
    .pk-faq-a {
      margin: 0 0 16px;
      font: 300 13px/1.5 var(--pk-font-sans);
    }
  }
</style>

<script>
  // Plain toggle: flip the .is-open class. All the height animation is
  // CSS-only via grid-template-rows: 0fr ↔ 1fr.
  document.querySelectorAll<HTMLElement>('[data-pk-faq]').forEach((row) => {
    const trigger = row.querySelector<HTMLElement>('[data-pk-faq-trigger]');
    if (!trigger) return;
    function toggle() {
      const next = !row.classList.contains('is-open');
      row.classList.toggle('is-open', next);
      trigger?.setAttribute('aria-expanded', String(next));
    }
    trigger.addEventListener('click', toggle);
    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle();
      }
    });
  });
</script>
