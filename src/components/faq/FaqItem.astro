---
interface Props {
  q: string;
  a?: string | undefined;
  open?: boolean | undefined;
}
const { q, a, open = false } = Astro.props;
---

<div class={`pk-faq-row${open ? ' is-open' : ''}`} data-pk-faq>
  <div
    class="pk-faq-summary"
    role="button"
    tabindex="0"
    aria-expanded={open ? 'true' : 'false'}
    data-pk-faq-trigger
  >
    <h3 class="pk-faq-q">{q}</h3>
    <!-- Two-span cross icon: horizontal stroke always visible, vertical collapses on open -->
    <span class="pk-faq-glyph" aria-hidden="true">
      <span class="pk-faq-glyph-h"></span>
      <span class="pk-faq-glyph-v"></span>
    </span>
  </div>
  <div class="pk-faq-panel" data-pk-faq-panel>
    <div class="pk-faq-panel-inner">
      <div class="pk-faq-panel-slide">
        {
          a ? (
            <p class="pk-faq-a">{a}</p>
          ) : (
            <p class="pk-faq-a pk-faq-a-empty">Answer coming soon.</p>
          )
        }
      </div>
    </div>
  </div>
</div>

<style is:global>
  .pk-faq-row .pk-faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    user-select: none;
    gap: 24px;
  }
  .pk-faq-q {
    margin: 0;
    font: 500 28px/1 var(--pk-font-sans);
    letter-spacing: -0.02em;
    color: var(--pk-ink-alt);
    flex: 1;
    transition: color 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .pk-faq-row:hover .pk-faq-q {
    color: var(--pk-ink);
  }
  .pk-faq-row.is-open .pk-faq-q {
    color: var(--pk-brand);
  }

  /* Two-span cross icon */
  .pk-faq-glyph {
    position: relative;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--pk-ink-alt);
    flex: none;
    transition:
      color 0.35s cubic-bezier(0.32, 0.72, 0, 1),
      transform 0.45s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .pk-faq-row.is-open .pk-faq-glyph {
    color: var(--pk-brand);
    transform: rotate(180deg);
  }
  /* Horizontal stroke — always visible */
  .pk-faq-glyph-h {
    position: absolute;
    left: 6px;
    right: 6px;
    top: 50%;
    height: 2px;
    background: currentColor;
    transform: translateY(-50%);
  }
  /* Vertical stroke — collapses to 0 when open */
  .pk-faq-glyph-v {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 50%;
    width: 2px;
    background: currentColor;
    transform-origin: center;
    transform: translateX(-50%) scaleY(1);
    transition: transform 0.45s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .pk-faq-row.is-open .pk-faq-glyph-v {
    transform: translateX(-50%) scaleY(0);
  }

  /* Smooth CSS-only accordion: grid row tween from 0fr → 1fr. No JS
   * measurement, no max-height snapping, no double motions. */
  .pk-faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .pk-faq-row.is-open .pk-faq-panel {
    grid-template-rows: 1fr;
  }
  .pk-faq-panel-inner {
    min-height: 0;
    overflow: hidden;
  }
  /* Slide + fade on the content inside the panel */
  .pk-faq-panel-slide {
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 0.4s cubic-bezier(0.32, 0.72, 0, 1),
      transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .pk-faq-row.is-open .pk-faq-panel-slide {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.05s;
  }
  .pk-faq-a {
    margin: 16px 0 0;
    font: 300 22px/1.4 var(--pk-font-sans);
    color: var(--pk-mute-2);
  }
  .pk-faq-a-empty {
    color: var(--pk-mute-3);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .pk-faq-row {
      border-top: 1px solid var(--pk-line);
    }
    .pk-faq-row .pk-faq-summary {
      padding: 16px 0;
      align-items: flex-start;
      gap: 12px;
    }
    .pk-faq-q {
      font: 500 16px/1.3 var(--pk-font-sans);
      letter-spacing: -0.01em;
    }
    .pk-faq-glyph {
      width: 24px;
      height: 24px;
    }
    .pk-faq-glyph-h {
      left: 4px;
      right: 4px;
    }
    .pk-faq-glyph-v {
      top: 4px;
      bottom: 4px;
    }
    .pk-faq-a {
      margin: 0 0 16px;
      font: 300 13px/1.5 var(--pk-font-sans);
    }
  }
</style>

<script>
  // Single-open accordion: opening one row closes all siblings.
  // Height animation is CSS-only via grid-template-rows: 0fr ↔ 1fr.
  document.querySelectorAll<HTMLElement>('[data-pk-faq]').forEach((row) => {
    const trigger = row.querySelector<HTMLElement>('[data-pk-faq-trigger]');
    if (!trigger) return;

    function toggle() {
      const isOpen = row.classList.contains('is-open');
      // Close all rows in the same list
      const siblings =
        row.closest('.pk-faq-list')?.querySelectorAll<HTMLElement>('[data-pk-faq]') ?? [];
      siblings.forEach((sibling) => {
        sibling.classList.remove('is-open');
        sibling.querySelector('[data-pk-faq-trigger]')?.setAttribute('aria-expanded', 'false');
      });
      // Open this one unless it was already open
      if (!isOpen) {
        row.classList.add('is-open');
        trigger?.setAttribute('aria-expanded', 'true');
      }
    }

    trigger.addEventListener('click', toggle);
    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggle();
      }
    });
  });
</script>
