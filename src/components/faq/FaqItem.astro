---
interface Props {
  q: string;
  a?: string | undefined;
  open?: boolean | undefined;
}
const { q, a, open = false } = Astro.props;
---

<details class="pk-faq-row" open={open}>
  <summary class="pk-faq-summary">
    <h3
      style="margin:0;font:500 28px/1 var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink-alt)"
    >
      {q}
    </h3>
    <span
      class="pk-faq-glyph"
      aria-hidden="true"
      style="font:400 24px/1 var(--pk-font-mono);color:var(--pk-ink-alt);transition:transform 0.2s ease, color 0.2s ease"
    >
      <span class="pk-faq-glyph-closed">→</span><span class="pk-faq-glyph-open">−</span>
    </span>
  </summary>
  {a && <p style="margin:16px 0 0;font:300 22px/1.4 var(--pk-font-sans);color:#808080">{a}</p>}
</details>

<style is:global>
  .pk-faq-row .pk-faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    gap: 24px;
  }
  .pk-faq-row summary::-webkit-details-marker {
    display: none;
  }
  .pk-faq-row .pk-faq-glyph-open {
    display: none;
  }
  .pk-faq-row[open] .pk-faq-glyph-closed {
    display: none;
  }
  .pk-faq-row[open] .pk-faq-glyph-open {
    display: inline;
  }
  .pk-faq-row:hover .pk-faq-glyph {
    color: var(--pk-brand);
    transform: translateX(2px);
  }
  .pk-faq-row[open]:hover .pk-faq-glyph {
    transform: rotate(180deg);
  }
</style>
