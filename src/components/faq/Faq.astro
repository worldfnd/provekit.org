---
import FaqItem from './FaqItem.astro';
import ArrowRight from '~/components/icons/ArrowRight.astro';
import { faqEntries } from '~/content/faq';
---

<section
  class="pk-faq-section"
  style="width:1600px;max-width:100%;background:#fff;border:1px solid var(--pk-line)"
  aria-labelledby="faq-title"
>
  <div class="pk-tab" style="border-top:0;border-left:0">FREQUENTLY ASKED QUESTIONS</div>

  <div
    class="pk-faq-body"
    style="padding:var(--pk-pad-panel-y) var(--pk-pad-panel-x);display:flex;justify-content:flex-end;position:relative;overflow:hidden"
  >
    <img
      src="/figma/faq-bloom-v2.png"
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      class="pk-faq-bloom"
      style="position:absolute;left:-340px;top:-260px;width:1280px;height:1280px;object-fit:contain;pointer-events:none"
    />
    <div
      class="pk-reveal pk-faq-inner"
      style="width:880px;max-width:100%;display:flex;flex-direction:column;gap:48px;position:relative;z-index:1"
    >
      <h2
        id="faq-title"
        class="pk-display-headline"
        style="margin:0;font:500 72px/72px var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink);white-space:pre-line"
      >
        {'Comprehensive list of\nanswers to all your questions'}
      </h2>
      <div class="pk-faq-list" style="display:flex;flex-direction:column;gap:36px">
        {
          faqEntries.map((entry, i) => (
            <>
              <FaqItem q={entry.q} a={entry.a} open={entry.open} />
              {i < faqEntries.length - 1 && (
                <div style="border-top:1px solid var(--pk-line)" aria-hidden="true" />
              )}
            </>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="pk-faq-cta pk-row-stack"
    style="display:flex;justify-content:space-between;align-items:center;padding:24px;border-top:1px solid var(--pk-line);gap:16px;flex-wrap:wrap"
  >
    <div
      class="pk-faq-cta-copy"
      style="font:500 40px/1 var(--pk-font-sans);letter-spacing:-0.02em;color:var(--pk-ink)"
    >
      Need more information or help?
    </div>
    <!--email_off-->
    <a
      href="mailto:remco@world.org"
      class="pk-btn pk-btn--primary"
      style="height:52px;padding:8px 16px;min-width:208px"
    >
      CONTACT US
      <ArrowRight />
    </a>
    <!--/email_off-->
  </div>
</section>

<style>
  @media (min-width: 721px) and (max-width: 1199px) {
    #faq-title {
      font-size: 38px !important;
      line-height: 1.15 !important;
      white-space: normal !important;
    }
    .pk-faq-cta-copy {
      font-size: 24px !important;
    }
    .pk-faq-inner {
      gap: 32px !important;
    }
  }

  @media (max-width: 720px) {
    .pk-faq-bloom {
      display: none !important;
    }
    .pk-faq-body {
      justify-content: flex-start !important;
    }
    .pk-faq-inner {
      gap: 20px !important;
    }
    .pk-faq-list {
      gap: 0 !important;
    }
    .pk-faq-bloom {
      width: 600px !important;
      height: 600px !important;
      left: -200px !important;
      top: -160px !important;
      opacity: 0.7;
    }
    .pk-faq-cta-copy {
      font-size: 22px !important;
      line-height: 1.2 !important;
    }
  }
</style>
