---
import FaqItem from './FaqItem.astro';
import { faqEntries } from '~/content/faq';
---

<div class="py-24">
  <div class="grid gap-12 md:grid-cols-[1fr_2fr] md:items-start">
    <div>
      <p class="pk-reveal"><span class="pk-eyebrow">FREQUENTLY ASKED QUESTIONS</span></p>
      <h2 id="faq-title" class="pk-h2 pk-reveal mt-4">
        Comprehensive list of answers to all your questions
      </h2>

      <!-- Z-icon with peach/pink radial bloom -->
      <figure class="pk-reveal relative mt-16 w-fit" aria-hidden="true">
        <span
          class="absolute -inset-12 -z-10 block opacity-90"
          style="background: radial-gradient(closest-side at 50% 50%, var(--color-bloom-pink) 0%, transparent 70%); filter: blur(40px);"
        ></span>
        <img src="/figma/faq-icon.png" alt="" width="220" height="220" loading="lazy" />
      </figure>
    </div>
    <div class="pk-reveal">
      {faqEntries.map((entry, i) => <FaqItem q={entry.q} a={entry.a} index={i} />)}
    </div>
  </div>

  <!-- Need more help? + Contact Us — full-width strip below the FAQ list -->
  <div
    class="pk-reveal mt-16 flex flex-col items-start justify-between gap-6 border-t border-[color:var(--color-line)] pt-10 md:flex-row md:items-center"
  >
    <p class="pk-h2 max-w-xl">Need more information or help?</p>
    <a href="mailto:hello@provekit.org" class="pk-btn pk-btn--primary" data-todo="contact">
      Contact Us
      <span aria-hidden="true">→</span>
    </a>
  </div>
</div>
